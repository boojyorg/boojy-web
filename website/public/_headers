/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin

# Astro emits content-hashed assets here — safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# NOTE: no /*.css or /*.js rules. Every CSS/JS file Astro builds is content-hashed
# under /_astro/ (covered above). A generic /*.css or /*.js rule ALSO matches those
# hashed files, and Cloudflare _headers *combines* all matching rules — that appends
# a conflicting second Cache-Control (e.g. `…immutable, …max-age=3600, must-revalidate`).
# There are no non-hashed CSS/JS assets, so such rules add nothing but the conflict.
