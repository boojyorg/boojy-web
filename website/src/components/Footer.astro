---
import { GITHUB_ICON_PATH, YOUTUBE_ICON_PATH } from '../content/site';
---

<footer class="footer">
  <div class="container">
    <nav class="footer-row-1">
      <a href="/audio/">Audio</a>
      <a href="/notes/">Notes</a>
      <a href="/design/">Design</a>
      <a href="/cloud/">Cloud</a>
      <a href="/news/">News</a>
      <a href="/privacy/">Privacy</a>
      <a href="/terms/">Terms</a>
    </nav>
    <div class="footer-row-2">
      <a href="https://github.com/boojyorg" target="_blank" aria-label="GitHub" class="footer-icon" rel="noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d={GITHUB_ICON_PATH} />
        </svg>
      </a>
      <a href="https://youtube.com/@boojy" target="_blank" aria-label="YouTube" class="footer-icon" rel="noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d={YOUTUBE_ICON_PATH} />
        </svg>
      </a>
      <span class="footer-sep">&middot;</span>
      <a href="mailto:tyr@boojy.org" class="footer-email">tyr@boojy.org</a>
      <span class="footer-sep">&middot;</span>
      <span class="footer-copy">&copy; 2026 Boojy</span>
    </div>
  </div>
