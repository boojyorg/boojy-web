---
import { COMING_SOON } from '../content/site';

// Lucide "cloud" — the stand-in glyph for the Cloud card (no screenshot to show).
const CLOUD_ICON = 'M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z';
---

<section class="coming-soon">
  <div class="container">
    <h2 class="coming-soon-title">Coming soon</h2>
    <div class="product-cards coming-soon-grid">
      {
        COMING_SOON.map((item) => {
          // Cloud links to its waitlist; Design has no page yet, so it's a plain card.
          const Wrapper = item.cta ? 'a' : 'div';
          return (
            <Wrapper
              class="product-card coming-soon-card"
              data-product={item.id}
              {...(item.cta ? { href: item.cta.href } : {})}
            >
              <div class="product-card-img">
                {item.visual.kind === 'image' ? (
                  <img src={item.visual.src} alt={item.visual.alt} loading="lazy" />
                ) : (
                  <div class="cloud-placeholder">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d={CLOUD_ICON} />
                    </svg>
                  </div>
                )}
                <span class="product-card-badge coming-soon-badge">Coming soon</span>
              </div>
              <div class="product-card-body">
                <p class="coming-soon-name">{item.name}</p>
                <p class="product-card-description">{item.description}</p>
                {item.cta ? (
                  <span class="product-card-cta coming-soon-cta-btn">{item.cta.label}</span>
                ) : (
                  <span class="coming-soon-soon">In the works</span>
                )}
              </div>
            </Wrapper>
          );
        })
      }
    </div>
  </div>
</section>
