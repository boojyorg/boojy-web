---
import { PRODUCT_CARDS, STAGE_LABELS } from '../content/site';
---

<section class="products-section">
  <div class="container">
    <div class="product-cards reveal reveal-d3">
      {
        PRODUCT_CARDS.map((product) => {
          // Live products link out; Design has no page yet, so it's a plain card.
          const Wrapper = product.href ? 'a' : 'div';
          return (
            <Wrapper
              class:list={['product-card', { 'coming-soon-card': product.comingSoon }]}
              data-product={product.id}
              {...(product.href ? { href: product.href } : {})}
            >
              <div class="product-card-img">
                {product.visual.kind === 'image' ? (
                  <img src={product.visual.src} alt={product.visual.alt} loading="lazy" />
                ) : (
                  <div class="card-placeholder">
                    {/* Lucide "image" — stand-in for a product with no screenshot yet. */}
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                      <circle cx="9" cy="9" r="2" />
                      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                    </svg>
                  </div>
                )}
                <span class:list={['product-card-badge', { 'coming-soon-badge': product.comingSoon }]}>
                  {product.comingSoon ? 'Coming soon' : product.stage ? STAGE_LABELS[product.stage] : ''}
                </span>
              </div>
              <div class="product-card-body">
                {product.logo ? (
                  <img
                    src={product.logo.src}
                    alt={product.logo.alt}
                    class="product-card-logo"
                    loading="lazy"
                  />
                ) : (
                  <p class="product-card-name">{product.name}</p>
                )}
                <p class="product-card-description">{product.description}</p>
                {product.comingSoon ? (
                  <span class="product-card-cta product-card-cta-disabled" aria-disabled="true">
                    Coming soon
                  </span>
                ) : (
                  <span class="product-card-cta">Learn more →</span>
                )}
              </div>
            </Wrapper>
          );
        })
      }
    </div>
  </div>
</section>
