---
import { getCollection } from 'astro:content';
import { Feedback } from '../components/Feedback';
import ProductCards from '../components/ProductCards.astro';
import { WHY_POINTS, WHY_STORY } from '../content/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/hub.css';

// Newest news post → the homepage "Latest" teaser (null if none written yet).
const latestNews = (await getCollection('news')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)[0];
---

<BaseLayout path="/">
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Boojy',
      url: 'https://boojy.org',
      logo: 'https://boojy.org/images/Boojy_Image_Logo.png',
      description: 'Free creative software. Music production, note-taking, and cloud storage.',
      sameAs: ['https://github.com/boojyorg', 'https://youtube.com/@boojy'],
    })}
  />

  <!-- Hero -->
  <section class="hub-hero">
    <div class="hub-hero-glow" aria-hidden="true" data-glow></div>
    <div class="container">
      <div class="hub-hero-title reveal">
        <img src="/images/boojy-logo.svg" alt="Boojy" class="hub-hero-logo" />
        <img src="/images/Boojy_Image_Logo.png" alt="" class="hub-hero-icon" />
      </div>
      <p class="hub-tagline reveal reveal-d1">Your creative space.</p>
      <p class="hub-tagline-sub reveal reveal-d2">Free, open source software. Made by Tyr.</p>
    </div>
  </section>

  <!-- Product grid — Audio · Notes · Design · Cloud (2×2). -->
  <ProductCards />

  <!-- Why Boojy — personal story + the promises. The "about". A centered card. -->
  <section class="why-boojy">
    <div class="container">
      <div class="why-boojy-card">
        <h2 class="why-boojy-title">Why Boojy</h2>
        <p class="why-boojy-lead">{WHY_STORY}</p>
        <ul class="why-boojy-points">
          {
            WHY_POINTS.map((point) => (
              <li class="why-point">
                <span class="why-point-check" aria-hidden="true">✓</span>
                <span class="why-point-text">
                  <strong class="why-point-label">{point.label}</strong>
                  <span class="why-point-detail">{point.detail}</span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Latest — newest /news post, the "this is alive" closer before the feedback ask. -->
  {
    latestNews && (
      <section class="hub-news">
        <div class="container">
          <a href={`/news/${latestNews.id}/`} class="hub-news-card">
            <span class="hub-news-eyebrow">Latest · {latestNews.data.title}</span>
            <p class="hub-news-summary">{latestNews.data.summary}</p>
            <span class="hub-news-cta">All news →</span>
          </a>
        </div>
      </section>
    )
  }

  <!-- Feedback — real form → Supabase Edge Function + Turnstile. -->
  <section class="feedback" id="feedback">
    <div class="container">
      <div class="feedback-inner">
        <h2 class="feedback-title">Found a bug? Got an idea?</h2>
        <p class="feedback-sub">Tell me — it goes straight to my inbox.</p>
        <Feedback client:visible />
      </div>
    </div>
  </section>
</BaseLayout>
