---
import ProductCards from '../components/ProductCards.astro';
import ProductCloudCard from '../components/ProductCloudCard.astro';
import { CLOUD_DESCRIPTION } from '../content/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/hub.css';
---

<BaseLayout path="/">
  <section class="hub-hero">
    <div class="hub-hero-glow" aria-hidden="true" data-glow></div>
    <div class="container">
      <div class="hub-hero-title reveal">
        <img src="/images/boojy-logo.svg" alt="Boojy" class="hub-hero-logo" />
        <img src="/images/Boojy_Image_Logo.png" alt="" class="hub-hero-icon" />
      </div>
      <p class="hub-tagline reveal reveal-d1">Free, open-source creative software.</p>
      <p class="hub-tagline-sub reveal reveal-d2">Made by Tyr.</p>
    </div>
  </section>
  <ProductCards />
  <ProductCloudCard
    cardClassName="cloud-card"
    ctaClassName="cloud-cta"
    description={CLOUD_DESCRIPTION}
  />
</BaseLayout>
