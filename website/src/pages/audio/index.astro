---
import { AudioDownload } from '../../components/AudioDownload';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLatestRelease } from '../../lib/github-release';
import '../../styles/audio.css';

// Build-time fetch — the version is baked into the static HTML and re-fetched on each
// deploy. getLatestRelease never throws (falls back on any error/timeout). Audio ships
// stable, version-less asset names, so only the version string needs the live release.
const release = await getLatestRelease('boojyorg/boojy-audio', { fallbackVersion: 'v0.5.2 Beta' });

// Feature checklist — mirrors boojy-audio's FEATURE_TRACKER for the tagged release.
// "Coming Soon" sticks to the next release (v0.6 "Sound") — it's a public commitment,
// so keep it to what's actually scheduled. 6 + 6 so the two cards match in height
// (free / VST3 / beginner-friendly live in the value-prop cards above, not repeated here).
const features = [
  { title: 'Multi-track timeline', detail: 'audio and MIDI side by side' },
  { title: 'Recording', detail: 'mic or interface, MIDI keyboard, count-in, punch in/out' },
  { title: 'Piano roll', detail: 'velocity, quantize, scale highlighting' },
  { title: 'Mixer', detail: 'faders, pan, mute/solo, send and return buses' },
  { title: 'Built-in effects', detail: 'EQ, compressor, reverb, delay, chorus' },
  { title: 'Export', detail: 'WAV, MP3, per-track stems, MIDI in and out' },
];

const comingSoon = [
  { title: 'Drum kit', detail: 'pad grid with starter sounds' },
  { title: 'Step sequencer', detail: 'program beats on a grid' },
  { title: 'Automation', detail: 'draw volume and pan changes over time' },
  { title: 'Input monitoring', detail: 'hear yourself while you record' },
  { title: 'Improved effects', detail: 'better reverb, EQ, compressor' },
  { title: 'More clip tools', detail: 'join, reverse, normalize' },
];
---

<BaseLayout path="/audio/">
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Boojy Audio',
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'macOS, Windows',
      url: 'https://boojy.org/audio/',
      description: 'A free, simple music studio for macOS and Windows. Perfect for making your first beat.',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    })}
  />
  <section class="audio-hero">
    <div class="audio-hero-glow" aria-hidden="true" data-glow></div>
    <div class="container">
      <h1 class="sr-only">Boojy Audio — a free, simple music studio for macOS and Windows</h1>
      <div class="audio-hero-title reveal">
        <img src="/images/boojy-logo.svg" alt="Boojy" class="audio-hero-logo" />
        <img src="/images/audio-text-logo.png" alt="Audio" class="audio-hero-product" />
      </div>
      <p class="audio-tagline reveal reveal-d1">Music production without the barriers.</p>
      <AudioDownload client:load versionText={release.versionText} />
    </div>
  </section>

  <section class="audio-screenshot-section">
    <div class="container">
      <div class="audio-screenshot-wrapper reveal reveal-d3">
        <img
          src="/images/audio-screenshot-v0.5.2.png"
          alt="Boojy Audio"
          class="audio-screenshot"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="audio-cards-section">
    <div class="container">
      <div class="audio-features-grid">
        <div class="audio-feature-card reveal">
          <svg
            class="audio-feature-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="m9 12 2 2 4-4"></path>
          </svg>
          <h3>Completely Free</h3>
          <p>No subscriptions, no paywalls. Free forever.</p>
        </div>
        <div class="audio-feature-card reveal reveal-d1">
          <svg
            class="audio-feature-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M9 18V5l12-2v13"></path>
            <circle cx="6" cy="18" r="3"></circle>
            <circle cx="18" cy="16" r="3"></circle>
          </svg>
          <h3>Plugin Support</h3>
          <p>Use VST3 instruments and effects.</p>
        </div>
        <div class="audio-feature-card reveal reveal-d2">
          <svg
            class="audio-feature-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          </svg>
          <h3>Beginner Friendly</h3>
          <p>Clean interface. No overwhelming menus.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="audio-features-section">
    <div class="container">
      <div class="audio-features-card reveal">
        <h2>Features</h2>
        <div class="audio-features-columns">
          <div class="audio-features-col">
            <h3>Current</h3>
            <ul class="audio-feature-list">
            {
              features.map((item) => (
                <li>
                  <svg
                    class="audio-feature-check"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  <span>
                    <strong>{item.title}</strong> — {item.detail}
                  </span>
                </li>
              ))
            }
            </ul>
          </div>
          <div class="audio-features-col audio-features-col-soon">
            <h3>Coming Soon</h3>
            <ul class="audio-feature-list">
            {
              comingSoon.map((item) => (
                <li>
                  <svg
                    class="audio-feature-check"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                  </svg>
                  <span>
                    <strong>{item.title}</strong> — {item.detail}
                  </span>
                </li>
              ))
            }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
