---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/news.css';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  path={`/news/${post.id}/`}
  title={`${post.data.title} – Boojy News`}
  description={post.data.summary}
  ogType="article"
  publishedTime={post.data.date}
>
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: post.data.title,
      description: post.data.summary,
      datePublished: post.data.date.toISOString(),
      url: `https://boojy.org/news/${post.id}/`,
      publisher: { '@type': 'Organization', name: 'Boojy', url: 'https://boojy.org' },
    })}
  />
  <article class="news-post">
    <div class="container news-post-inner">
      <a href="/news/" class="news-back">← News</a>
      <h1 class="news-post-title">{post.data.title}</h1>
      <div class="news-post-body">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
