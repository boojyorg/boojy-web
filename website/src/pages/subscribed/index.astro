---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/audio.css';
---

<BaseLayout path="/subscribed/">
  <section class="subscribed-hero">
    <div class="container">
      <div class="subscribed-box">
        <img src="/images/Boojy_Image_Logo.png" alt="Boojy" class="subscribed-logo" loading="lazy" />
        <h1>You're subscribed!</h1>
        <p>Expect updates on what's new with Boojy.</p>
        <a href="/" class="btn btn-primary">Return to Boojy</a>
      </div>
    </div>
  </section>
</BaseLayout>
