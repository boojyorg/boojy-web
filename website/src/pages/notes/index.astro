---
import { NotesDownload } from '../../components/NotesDownload';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { findAssetUrl, getLatestRelease } from '../../lib/github-release';
import '../../styles/notes.css';

// Build-time fetch — version + real asset URLs are baked into the static HTML and
// re-fetched on each deploy. getLatestRelease never throws (falls back on any
// error/timeout). Notes' asset filenames embed the version, so the download URLs have
// to come from the live release, not a hardcoded path.
const release = await getLatestRelease('boojyorg/boojy-notes', { fallbackVersion: 'v0.3.0 Beta' });
const macArm64Url = findAssetUrl(release.assets, /arm64\.dmg$/) ?? null;
const winX64Url = findAssetUrl(release.assets, /Setup-.*\.exe$/) ?? null;

// Feature checklist — "Current" mirrors boojy-notes' FEATURE_TRACKER (all shipped);
// "Coming Soon" is near-term polish, deliberately light (Notes is feature-complete for v0.x).
const notesFeatures = [
  { title: 'Block editor', detail: 'slash commands, markdown shortcuts, drag & keyboard reorder' },
  {
    title: 'Rich blocks',
    detail: 'headings, lists, checkboxes, tables, callouts, code, images & files',
  },
  { title: 'Wikilinks & backlinks', detail: 'connect notes; tags with autocomplete' },
  { title: 'Organize & find', detail: 'nested folders, full-text search, in-note find' },
  { title: 'Cloud sync', detail: 'across devices, offline-ready, free up to 500 MB' },
  { title: 'Own your files', detail: 'notes are plain Markdown — import & round-trip, no lock-in' },
];

const notesComingSoon = [
  { title: 'Linux support', detail: 'desktop builds for Linux' },
  { title: 'Tablet & touch', detail: 'a more comfortable layout on phones and tablets' },
  { title: 'Smoother editing', detail: 'refined block drag-and-drop and editor animations' },
];
---

<BaseLayout path="/notes/">
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Boojy Notes',
      applicationCategory: 'ProductivityApplication',
      operatingSystem: 'macOS, Windows, Web',
      url: 'https://boojy.org/notes/',
      description: 'A calm space for your thoughts. Write in markdown, organize with folders. Free and runs in your browser.',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    })}
  />
  <section class="notes-hero">
    <div class="notes-hero-glow" aria-hidden="true" data-glow></div>
    <div class="container">
      <div class="notes-hero-title reveal">
        <img src="/images/boojy-logo.svg" alt="Boojy" class="notes-hero-logo" />
        <img src="/images/notes-text-logo.png" alt="Notes" class="notes-hero-product" />
      </div>
      <p class="notes-tagline reveal reveal-d1">Your notes. Your files. Your devices.</p>
      <NotesDownload
        client:load
        versionText={release.versionText}
        macArm64Url={macArm64Url}
        winX64Url={winX64Url}
      />
    </div>
  </section>

  <section class="notes-screenshot-section">
    <div class="container">
      <div class="notes-screenshot-wrapper reveal reveal-d3">
        <img
          src="/images/notes-screenshot-v0.1.png"
          alt="Boojy Notes"
          class="notes-screenshot"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="notes-features-section">
    <div class="container">
      <div class="notes-features-grid">
        <div class="notes-feature-card">
          <svg
            class="notes-feature-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"
            ></path>
            <path d="m15 5 4 4"></path>
          </svg>
          <h3>Markdown files</h3>
          <p>Write in markdown, rendered live. Your notes are plain files — always yours.</p>
        </div>
        <div class="notes-feature-card">
          <svg
            class="notes-feature-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
            <path d="M2 12h20"></path>
          </svg>
          <h3>Cross-platform</h3>
          <p>Web and desktop. Pick up where you left off.</p>
        </div>
        <div class="notes-feature-card">
          <svg
            class="notes-feature-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 20h.01"></path>
            <path d="M8.5 16.429a5 5 0 0 1 7 0"></path>
            <path d="M5 12.859a10 10 0 0 1 5.17-2.69"></path>
            <path d="M13.83 10.17A10 10 0 0 1 19 12.859"></path>
            <path d="M1.42 9a16 16 0 0 1 6.81-4.15"></path>
            <path d="M15.77 4.85A16 16 0 0 1 22.58 9"></path>
            <line x1="2" x2="22" y1="2" y2="22"></line>
          </svg>
          <h3>Offline first</h3>
          <p>Works offline, no account needed. Optional cloud sync across your devices.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="notes-checklist-section">
    <div class="container">
      <div class="notes-checklist-card reveal">
        <h2>Features</h2>
        <div class="notes-checklist-columns">
          <div class="notes-checklist-col">
            <h3>Current</h3>
            <ul class="notes-checklist-list">
              {
                notesFeatures.map((item) => (
                  <li>
                    <svg
                      class="notes-checklist-check"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                    <span>
                      <strong>{item.title}</strong> — {item.detail}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="notes-checklist-col notes-checklist-col-soon">
            <h3>Coming Soon</h3>
            <ul class="notes-checklist-list">
              {
                notesComingSoon.map((item) => (
                  <li>
                    <svg
                      class="notes-checklist-check"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </svg>
                    <span>
                      <strong>{item.title}</strong> — {item.detail}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
