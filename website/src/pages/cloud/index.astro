---
import { CLOUD_AUDIO_NOTE, CLOUD_ETHICS, CLOUD_INTRO, CLOUD_PRICING } from '../../content/cloud';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/cloud.css';
---

<BaseLayout path="/cloud/">
  <section class="cloud-hero">
    <div class="container">
      <h1 class="cloud-title">Boojy Cloud</h1>
      <p class="cloud-subtitle">{CLOUD_INTRO}</p>
    </div>
  </section>

  <section class="pricing-section">
    <div class="container">
      <div class="pricing-cards">
        {
          CLOUD_PRICING.map((plan) => (
            <div class:list={['pricing-card', { 'pricing-card-highlight': plan.highlight }]}>
              <span
                class:list={[
                  'pricing-status',
                  plan.status === 'live' ? 'pricing-status-live' : 'pricing-status-coming',
                ]}
              >
                {plan.status === 'live' ? 'Live now' : 'Coming'}
              </span>
              <h2 class="pricing-name">{plan.name}</h2>
              <div class="pricing-price">
                <span class="pricing-amount">{plan.amount}</span>
                <span class="pricing-period">{plan.period}</span>
              </div>
              <ul class="pricing-features">
                {plan.features.map((feature) => (
                  <li>
                    <span class="check">✓</span> {feature}
                  </li>
                ))}
              </ul>
              {plan.cta ? (
                <a
                  href={plan.cta.href}
                  class:list={[
                    'btn',
                    plan.highlight ? 'btn-primary' : 'btn-secondary',
                    'pricing-btn',
                  ]}
                >
                  {plan.cta.label}
                </a>
              ) : (
                <button
                  type="button"
                  class:list={[
                    'btn',
                    plan.highlight ? 'btn-primary' : 'btn-secondary',
                    'pricing-btn',
                  ]}
                  disabled
                >
                  Coming soon
                </button>
              )}
            </div>
          ))
        }
      </div>
      <p class="cloud-audio-note">{CLOUD_AUDIO_NOTE}</p>
    </div>
  </section>

  <section class="ethics-section">
    <div class="container">
      <h2 class="section-title">We believe in fair software</h2>
      <div class="ethics-grid">
        {
          CLOUD_ETHICS.map((item) => (
            <div class="ethics-item">
              <span class="ethics-check">✓</span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
